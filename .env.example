# Adaptive Trading OS — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is in .gitignore.

# ── Schwab API ──────────────────────────────────────────────
SCHWAB_API_KEY=
SCHWAB_APP_SECRET=
SCHWAB_REDIRECT_URI=https://127.0.0.1:8182
SCHWAB_TOKEN_PATH=schwab_token.json

# ── Telegram ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── AWS ──────────────────────────────────────────────────────
AWS_REGION=us-east-1
S3_RAW_BUCKET=
S3_NORMALIZED_BUCKET=
DYNAMODB_SIGNALS_TABLE=mes-signal-log
DYNAMODB_RULES_TABLE=
DYNAMODB_OUTCOMES_TABLE=
DYNAMODB_RISK_TABLE=
SECRETS_MANAGER_SECRET=trading-bot/telegram

# ── Tradovate (disabled until account >= $1,000) ─────────────
TRADOVATE_CLIENT_ID=
TRADOVATE_CLIENT_SECRET=
TRADOVATE_ENVIRONMENT=demo
LIVE_EXECUTION_ENABLED=false

# ── Operating Mode ───────────────────────────────────────────
# research | paper | live
TRADING_MODE=paper
LOG_LEVEL=INFO
